# Driver configuration. Copy to config.env and edit. config.env is gitignored.
# Source of truth for all tunables used by run.sh.

# --- Coding agent selection ---
# Which coding agent the driver runs for each phase session:
#   codex   OpenAI Codex CLI (codex exec)
#   claude  Claude Code CLI (claude -p)
#   gemini  Gemini CLI (gemini -p)
#   custom  Your own command from CUSTOM_AGENT_CMD below
# Leave empty to be asked interactively on the first run; the choice is then
# saved to config.env. Non-interactive runs require this to be set. Can also
# be provided as an environment variable for a one-off run.
DRIVER_AGENT="${DRIVER_AGENT:-}"

# --- Codex CLI invocation ---
# The headless Codex binary.
CODEX_BIN="codex"
# Model override (empty = default from Codex config). e.g. gpt-5-codex
CODEX_MODEL=""
# Config profile override (empty = default from Codex config).
CODEX_PROFILE=""
# Headless sessions must not wait for interactive approval prompts.
# Mapped to Codex config key approval_policy via `codex exec -c`.
CODEX_SANDBOX="workspace-write"
CODEX_APPROVAL="never"
# Running with approval "never" plus a writable sandbox means an agent edits
# and commits with no human in the loop. The driver refuses to start in that
# mode until you acknowledge it here (in your local config.env, not this
# example file). Prefer running the driver inside a container/VM boundary,
# and treat task briefs, prompt templates, and config.env as trusted inputs.
DRIVER_UNATTENDED_OK="false"
# Optional additional `codex exec` flags. Whitespace-separated simple tokens
# only (letters, digits, ._=/,:@+-). Quoting and shell metacharacters are
# rejected, so config.env content cannot expand into arbitrary flags.
# Examples: CODEX_EXTRA_ARGS="--color never --search"
CODEX_EXTRA_ARGS="--color never"

# --- Claude Code CLI invocation (DRIVER_AGENT="claude") ---
CLAUDE_BIN="claude"
CLAUDE_MODEL=""
# bypassPermissions runs headless with no approval prompts (requires the
# DRIVER_UNATTENDED_OK acknowledgment below). Any other value is passed to
# `claude --permission-mode` as-is (e.g. acceptEdits).
CLAUDE_PERMISSION_MODE="bypassPermissions"
# Same token rules as CODEX_EXTRA_ARGS.
CLAUDE_EXTRA_ARGS=""

# --- Gemini CLI invocation (DRIVER_AGENT="gemini") ---
GEMINI_BIN="gemini"
GEMINI_MODEL=""
# yolo runs headless with no approval prompts (requires the
# DRIVER_UNATTENDED_OK acknowledgment below). Other values: auto_edit, default.
GEMINI_APPROVAL_MODE="yolo"
# Same token rules as CODEX_EXTRA_ARGS.
GEMINI_EXTRA_ARGS=""

# --- Custom agent invocation (DRIVER_AGENT="custom") ---
# The full command the driver runs per phase; the phase prompt is appended as
# the final argument. Same token rules as CODEX_EXTRA_ARGS (no quoting or
# shell metacharacters). The command must run headlessly, print its
# transcript to stdout, and exit non-zero on failure.
# Example: CUSTOM_AGENT_CMD="opencode run --print-logs"
CUSTOM_AGENT_CMD=""

# --- Loop control ---
# Max implement<->verify attempts per task before the driver blocks and stops.
MAX_ATTEMPTS=4
# Seconds to wait between phase sessions (lets fs settle / servers restart).
PHASE_PAUSE=3
# Clear gitignored driver state/log runtime material after a successful unscoped full run.
# CLI precedence: --flush-on-complete or --no-flush-on-complete overrides this for one invocation.
FLUSH_ON_COMPLETE="${FLUSH_ON_COMPLETE:-true}"
# For task briefs linked to GitHub issues, add a completion comment and try to
# close the issue after the task commit succeeds. This is soft-only: GitHub
# failures are recorded in driver state but do not fail the committed task.
GITHUB_ISSUE_FINALIZE="${GITHUB_ISSUE_FINALIZE:-true}"

# --- Repo / git ---
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
# Branch the driver works on. It will create it from BASE_BRANCH if missing.
WORK_BRANCH="feat/agent-driver-build"
BASE_BRANCH="main"
# Commit, but NEVER push (explicit user requirement).
ALLOW_PUSH="false"

# --- Optional app stack used for runtime/browser verification ---
# auto: start the legacy backend/frontend verifier only when this repo has that stack.
# always: require the legacy verifier stack and block if it cannot start.
# never: skip stack startup; verifier must use repo checks and task-specific evidence.
VERIFY_STACK_MODE="auto"
# Interface the verify stack binds to. Keep the loopback default unless you
# genuinely need the verify servers reachable from other hosts: the backend
# runs in development mode against a copy of real data.
VERIFY_BIND_HOST="127.0.0.1"
# Use "auto" to allocate fresh free ports per run when the stack is started.
VERIFY_FRONTEND_PORT="auto"
VERIFY_BACKEND_PORT="auto"
# These are recalculated by the driver after auto ports are resolved.
VERIFY_BASE_URL="http://localhost:${VERIFY_FRONTEND_PORT}"
VERIFY_API_URL="http://localhost:${VERIFY_BACKEND_PORT}"
# SQLite DB the verify backend points at (copy of dev DB, so verification
# never mutates the canonical dev database).
VERIFY_DB="backend/stochron.driververify.db"
SOURCE_DB="backend/stochron.db"

# --- Rate limit handling ---
# Seconds to wait on first rate-limit hit (increases linearly on consecutive hits, caps at 12h).
RATE_LIMIT_COOLDOWN="${RATE_LIMIT_COOLDOWN:-900}"
# Max consecutive rate-limit hibernations per phase before blocking the task.
MAX_RATE_LIMIT_WAITS="${MAX_RATE_LIMIT_WAITS:-5}"

# --- Mock mode (for testing the driver itself) ---
# When DRIVER_MOCK=1, no real Codex sessions/servers run. A scripted fake responder
# drives the state machine so the control flow can be exercised deterministically.
DRIVER_MOCK="${DRIVER_MOCK:-0}"
